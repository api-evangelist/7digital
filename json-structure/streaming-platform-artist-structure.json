{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/7digital/refs/heads/main/json-structure/streaming-platform-artist-structure.json",
  "name": "Artist",
  "description": "Artist schema from 7digital API",
  "properties": {
    "id": {
      "type": "string",
      "example": "12345"
    },
    "name": {
      "type": "string",
      "example": "The Beatles"
    },
    "url": {
      "type": "uri",
      "example": "https://uk.7digital.com/artist/the-beatles"
    },
    "image": {
      "type": "uri",
      "example": "https://artwork-cdn.7static.com/static/img/artistimages/00/000/012/0000001234_350.jpg"
    },
    "sortName": {
      "type": "string",
      "example": "Beatles, The"
    }
  }
}