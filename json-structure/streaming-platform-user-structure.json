{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/7digital/refs/heads/main/json-structure/streaming-platform-user-structure.json",
  "name": "User",
  "description": "User schema from 7digital API",
  "properties": {
    "id": {
      "type": "string",
      "example": "500123"
    },
    "email": {
      "type": "string",
      "example": "jane.smith@example.com"
    },
    "firstName": {
      "type": "string",
      "example": "Jane"
    },
    "lastName": {
      "type": "string",
      "example": "Smith"
    },
    "country": {
      "type": "string",
      "example": "GB"
    },
    "createdAt": {
      "type": "datetime",
      "example": "2026-05-28T14:30:00Z"
    }
  }
}