{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/7digital/refs/heads/main/json-structure/api-payment-card-structure.json",
  "name": "PaymentCard",
  "description": "PaymentCard schema from 7digital API",
  "properties": {
    "cardId": {
      "type": "string",
      "example": "card-789012"
    },
    "last4": {
      "type": "string",
      "example": "4242"
    },
    "brand": {
      "type": "string",
      "enum": [
        "visa",
        "mastercard",
        "amex",
        "discover"
      ],
      "example": "visa"
    },
    "expiryMonth": {
      "type": "int32",
      "example": 12
    },
    "expiryYear": {
      "type": "int32",
      "example": 2028
    },
    "isDefault": {
      "type": "boolean",
      "example": true
    }
  }
}