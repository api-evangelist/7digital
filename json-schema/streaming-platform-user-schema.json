{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/7digital/refs/heads/main/json-schema/streaming-platform-user-schema.json",
  "title": "User",
  "description": "User schema from 7digital API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "500123"
    },
    "email": {
      "type": "string",
      "format": "email",
      "example": "jane.smith@example.com"
    },
    "firstName": {
      "type": "string",
      "example": "Jane"
    },
    "lastName": {
      "type": "string",
      "example": "Smith"
    },
    "country": {
      "type": "string",
      "example": "GB"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "example": "2026-05-28T14:30:00Z"
    }
  }
}